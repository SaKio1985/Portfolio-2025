---
const currentYear = new Date().getFullYear();
---

<footer class="bg-secondary text-text py-6 px-10 border-t border-gray-600">
  <div class="flex justify-between items-center max-w-6xl mx-auto flex-col md:flex-row gap-5">
    <div class="text-base">
      ibandorado © {currentYear}
    </div>
    <nav class="flex items-center gap-6">
      <a 
        href="https://github.com/SaKio1985" 
        target="_blank" 
        rel="noopener noreferrer" 
        aria-label="GitHub"
        class="text-text text-xl hover:text-accent transition-colors duration-300"
      >
        <i class="fab fa-github"></i>
      </a>
      <a 
        href="#" 
        target="_blank" 
        rel="noopener noreferrer" 
        aria-label="Frontend Mentor Profile"
        class="text-text text-xl hover:text-accent transition-colors duration-300"
      >
        <i class="fas fa-file-code"></i>
      </a>
      <a 
        href="https://www.linkedin.com/in/iban-dorado-171a4a24b/" 
        target="_blank" 
        rel="noopener noreferrer" 
        aria-label="LinkedIn"
        class="text-text text-xl hover:text-accent transition-colors duration-300"
      >
        <i class="fab fa-linkedin"></i>
      </a>
      <a 
        href="https://x.com/IbDorado" 
        target="_blank" 
        rel="noopener noreferrer" 
        aria-label="Twitter"
        class="text-text text-xl hover:text-accent transition-colors duration-300"
      >
        <i class="fab fa-twitter"></i>
      </a>
    </nav>
  </div>
</footer>